{
  "manifest_version": 2,
  "name": "Duplicate Merge Manager",
  "version": "0.5.2",
  "description": "Find and safely manage likely duplicate Zotero items.",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "applications": {
    "zotero": {
      "id": "duplicate-merge-manager@plugin.local",
      "update_url": "https://example.com/zotero-duplicate-merge-manager-plugin/updates.json",
      "strict_min_version": "7.0",
      "strict_max_version": "9.*"
    }
  }
}
